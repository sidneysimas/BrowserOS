{
  "name": "@browseros/claw-app",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "description": "WXT extension surface for BrowserClaw. React + shadcn (base-vega). Talks to @browseros/claw-server over hono-rpc.",
  "scripts": {
    "dev": "bun --env-file=../../.env.development wxt",
    "dev:web": "serve dist/chrome-mv3-dev -p 5174 --no-clipboard",
    "build": "wxt build",
    "build:dev": "bun --env-file=../../.env.development wxt build --mode development",
    "test": "bun run ../../scripts/run-bun-test.ts ./apps/claw-app",
    "zip": "wxt zip",
    "compile": "wxt prepare && tsc --noEmit",
    "typecheck": "wxt prepare && tsc --noEmit",
    "lint": "bunx biome check",
    "lint:fix": "bunx biome check --write --unsafe",
    "lint:doctor": "bunx react-doctor@latest -y --verbose"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@browseros/claw-server": "*",
    "@fontsource-variable/jetbrains-mono": "^5.2.5",
    "@fontsource-variable/schibsted-grotesk": "^5.2.5",
    "@fontsource/newsreader": "^5.2.5",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@rive-app/react-webgl2": "^4.29.0",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tabler/icons-react": "^3.34.1",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-table": "^8.21.3",
    "@xyflow/react": "^12.11.0",
    "ai": "6.0.208",
    "ansi-to-react": "^6.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "hono": "^4.12.3",
    "lucide-react": "^1.17.0",
    "media-chrome": "^4.19.1",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "posthog-js": "^1.160.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "~7.78.0",
    "react-jsx-parser": "^2.4.1",
    "react-query-kit": "^3.3.1",
    "react-router": "^7.12.0",
    "rrweb": "2.0.1",
    "rrweb-player": "2.0.1",
    "shiki": "^4.2.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.4.0",
    "tokenlens": "^1.3.1",
    "use-stick-to-bottom": "^1.1.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@types/chrome": "^0.1.28",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@wxt-dev/module-react": "^1.1.5",
    "linkedom": "^0.18.12",
    "serve": "^14.2.6",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.2",
    "wxt": "^0.20.18"
  }
}
