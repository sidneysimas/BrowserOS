{
  "name": "@browseros/claw-onboard",
  "type": "module",
  "private": true,
  "version": "0.0.5",
  "description": "Standalone Vite app for the BrowserClaw onboarding flow.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:chromium": "tsc --noEmit && vite build --mode chromium && bun scripts/verify-chromium-build.ts",
    "preview": "vite preview",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "bunx biome check",
    "lint:fix": "bunx biome check --write --unsafe"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@browseros/claw-server": "workspace:*",
    "@tabler/icons-react": "^3.34.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "~7.78.0",
    "react-router": "^7.12.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.2",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.2",
    "vite": "^7.0.0"
  }
}
