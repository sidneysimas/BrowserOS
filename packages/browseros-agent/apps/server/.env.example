# Server startup ports, resources, execution directories, and instance
# metadata come from the sidecar JSON passed with --config.
BROWSEROS_CONFIG_URL=https://llm.browseros.com/api/browseros-server/config

BROWSEROS_TRUSTED_ORIGINS=

# Telemetry
POSTHOG_API_KEY=
SENTRY_DSN=

NODE_ENV=development
LOG_LEVEL=info

# AI SDK DevTools
# 1. Set BROWSEROS_AI_SDK_DEVTOOLS=true in apps/server/.env.development.
# 2. Run `cd apps/server && bun run devtools` to open the viewer.
#    From the monorepo root, `bun run devtools` opens the same viewer.
# 3. In another apps/server terminal, run `bun --env-file=.env.development src/index.ts --config ../../config.dev.json`.
# 4. Confirm the `AI SDK DevTools middleware enabled` log line; captures need a v3 model.
# BROWSEROS_AI_SDK_DEVTOOLS=true

# Testing
BROWSEROS_TEST_HEADLESS=false
